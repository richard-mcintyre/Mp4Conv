{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "RootPath": "O:\\Video",
    "Folders": [
      "O:\\Video\\__rcmtest",
      "O:\\Video",
      "O:\\Video\\__rcmtest3"
    ],
    "VideoCodecs": [
      {
        "Name": "H.264",
        "Codec": "libx264"
      },
      {
        "Name": "H.265/HEVC",
        "Codec": "libx265"
      },
      {
        "Name": "AV1",
        "Codec": "libsvtav1"
      },
      {
        "Name": "mpeg4",
        "Codec": "mpeg4"
      },
      {
        "Name": "libvpx-vp9",
        "Codec": "libvpx-vp9"
      }
    ],
    "AudioCodecs": [
      {
        "Name": "AAC",
        "Codec": "aac"
      },
      {
        "Name": "MP3",
        "Codec": "libmp3lame"
      },
      {
        "Name": "Opus",
        "Codec": "libopus"
      },
      {
        "Name": "ac3",
        "Codec": "ac3"
      },
      {
        "Name": "flac",
        "Codec": "flac"
      }
    ],
  }
}
