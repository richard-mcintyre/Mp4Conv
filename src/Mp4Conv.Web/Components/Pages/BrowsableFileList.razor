@page "/browse"
@using Mp4Conv.Web.Models

<PageTitle>Browse File System</PageTitle>

<div class="page-header">
    <h1>Browse File System</h1>
</div>

@if (string.IsNullOrEmpty(this.CurrentPath))
{
    <div class="alert alert-danger">Root folder not configured.</div>
}
else if (!this.PathExists)
{
    <div class="alert alert-danger">Folder does not exist: @this.CurrentPath</div>
}
else
{
    <div class="folder-list-layout">
        <div class="folder-list-files">
            <div class="browsable-path-bar">
                @if (this.CanNavigateUp)
                {
                    <button class="btn btn-ghost btn-sm" @onclick="this.NavigateUp">↑ Up</button>
                }
                <span class="browsable-current-path" title="@this.CurrentPath">@this.CurrentPath</span>
            </div>

            @if ((this.SubFolders is null || this.SubFolders.Count == 0) &&
                 (this.Files is null || this.Files.Count == 0))
            {
                <div>No files or folders found.</div>
            }
            else
            {
                <input class="file-filter-input"
                       type="search"
                       placeholder="Filter..."
                       @bind="this.FilterText"
                       @bind:event="oninput" />

                @if (this.SubFolders is not null)
                {
                    @foreach (string folder in this.FilteredFolders)
                    {
                        <div>
                            <button class="file-list-label browsable-folder-btn" @onclick="() => this.NavigateTo(folder)">
                                <img src="icons/folder.svg" class="file-icon" alt="folder" />
                                @System.IO.Path.GetFileName(folder)
                            </button>
                        </div>
                    }
                }

                @if (this.Files is not null && this.Files.Count > 0)
                {
                    @for (int i = 0; i < this.FilteredFiles.Count; i++)
                    {
                        FileModel fileModel = this.FilteredFiles[i];
                        int index = i;
                        string ext = System.IO.Path.GetExtension(fileModel.FilePathAndName).ToLowerInvariant();
                        string icon = ext switch { ".mp4" => "mp4", ".mkv" => "mkv", _ => "file" };
                        <div>
                            <label class="file-list-label"
                                   @onclick="e => this.OnFileClick(fileModel, index, e)"
                                   @onclick:preventDefault>
                                <input type="checkbox" checked="@this.SelectedFiles.Contains(fileModel)" />
                                <img src="icons/@(icon).svg" class="file-icon" alt="@ext" />
                                @System.IO.Path.GetFileName(fileModel.FilePathAndName)
                            </label>
                        </div>
                    }
                }
            }
        </div>

        @if (this.SelectedFiles.Count > 0)
        {
            <div class="folder-list-settings">
                <ConversionSettings SelectedFiles="this.SelectedFiles" />
            </div>
        }
    </div>
}
